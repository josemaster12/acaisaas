# ===========================================
# PRONTO AÇAÍ NOW - Variáveis de Ambiente
# ===========================================

# -------------------------------------------
# MODO DESENVOLVIMENTO (FRONTEND MOCKADO)
# -------------------------------------------
# Para usar apenas o frontend sem backend:
# - Não precisa configurar nada
# - O sistema usa dados mockados automaticamente
# - Todas as funcionalidades funcionam sem backend

# -------------------------------------------
# MODO PRODUÇÃO (COM BACKEND)
# -------------------------------------------
# Quando tiver um backend rodando, configure:

# URL da API Backend
VITE_API_URL=http://localhost:3333

# -------------------------------------------
# SUPABASE (Opcional - para backend)
# -------------------------------------------
# Se for usar Supabase no backend:

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PROJECT_ID=seu-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica

# -------------------------------------------
# NOTAS
# -------------------------------------------
# 1. Copie este arquivo para .env
# 2. Preencha com seus dados reais
# 3. Para modo mock, não precisa configurar nada
# 4. Para modo real, configure VITE_API_URL

# -------------------------------------------
# EXEMPLO DE USO
# -------------------------------------------

# Modo Mock (Desenvolvimento Frontend):
# - Deixe USE_MOCK_API = true em src/services/api.ts
# - Não precisa configurar este arquivo
# - Rode: npm run dev

# Modo Real (Produção):
# - Deixe USE_MOCK_API = false em src/services/api.ts
# - Configure VITE_API_URL acima
# - Certifique-se que o backend está rodando
# - Rode: npm run dev
