# ============================================
# VARIAVEIS DE AMBIENTE - VERCEL
# ============================================
# Copie este arquivo para .env e preencha os valores
# No Vercel, configure estas variaveis no dashboard do projeto
# ============================================

# Supabase Configuration (OBRIGATORIO)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PROJECT_ID=seu-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua-chave

# Backend API (opcional - se usar backend separado)
VITE_API_URL=https://seu-backend.herokuapp.com

# Mock Mode
# true = usa dados mockados (sem banco de dados)
# false = usa Supabase (producao)
VITE_USE_MOCK=false

# ============================================
# INSTRUCOES PARA VERCEL
# ============================================
# 1. Acesse https://vercel.com/dashboard
# 2. Importe este projeto do GitHub
# 3. Em "Environment Variables", adicione:
#    - VITE_SUPABASE_URL
#    - VITE_SUPABASE_PROJECT_ID
#    - VITE_SUPABASE_PUBLISHABLE_KEY
#    - VITE_USE_MOCK=false
# 4. Clique em Deploy
# ============================================
